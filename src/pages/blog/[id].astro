---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base title={`${post.data.title}｜88茶葉`} description={post.data.description}>

  <article class="article">
    <div class="article-header">
      <div class="article-header-inner">
        <a href="/blog" class="back-link">← 回到茶知識</a>
        <div class="article-meta">
          <span class="article-date">{new Date(post.data.date).toLocaleDateString('zh-TW')}</span>
          {post.data.tags && post.data.tags.map((tag: string) => (
            <span class="article-tag">{tag}</span>
          ))}
        </div>
        <h1>{post.data.title}</h1>
      </div>
    </div>
    <div class="article-content">
      <div class="article-body">
        <Content />
      </div>
      <div class="article-cta">
        <div class="cta-divider">
          <span>🍃</span>
        </div>
        <p>想嚐嚐正宗台灣高山茶？</p>
        <a href="https://line.me/ti/p/%40wgc0409f" target="_blank" rel="noopener" class="cta-button">加 LINE 選茶下單 →</a>
      </div>
    </div>
  </article>

</Base>

<style>
  .article-header {
    background: linear-gradient(165deg, #1a2618 0%, #2d4228 40%, #1a2218 100%);
    color: var(--white);
    padding: calc(var(--section-pad) + 3rem) 2rem var(--section-pad);
  }
  .article-header-inner {
    max-width: var(--narrow-width);
    margin: 0 auto;
  }
  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5);
    margin-bottom: 2rem;
    transition: color var(--transition);
  }
  .back-link:hover { color: var(--gold); }
  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .article-date {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.4);
  }
  .article-tag {
    font-size: 0.7rem;
    background: rgba(200,169,110,0.15);
    color: var(--gold);
    padding: 0.15rem 0.6rem;
    letter-spacing: 0.03em;
  }
  .article-header h1 {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3.5vw, 2.2rem);
    line-height: 1.45;
    letter-spacing: 0.03em;
  }

  .article-content {
    max-width: var(--narrow-width);
    margin: 0 auto;
    padding: var(--section-pad) 2rem;
  }
  .article-body {
    background: var(--white);
    padding: 3rem;
    border: 1px solid var(--cream);
  }
  .article-body :global(h2) {
    font-family: var(--font-serif);
    color: var(--ink);
    margin: 2.5rem 0 1rem;
    font-size: 1.35rem;
    letter-spacing: 0.03em;
  }
  .article-body :global(h3) {
    font-family: var(--font-serif);
    color: var(--tea-green);
    margin: 2rem 0 0.6rem;
    font-size: 1.1rem;
  }
  .article-body :global(p) {
    margin-bottom: 1.2rem;
    color: var(--ink-light);
    line-height: 2;
    font-size: 0.95rem;
  }
  .article-body :global(ul), .article-body :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.2rem;
  }
  .article-body :global(li) {
    margin-bottom: 0.4rem;
    color: var(--ink-light);
    line-height: 1.9;
    font-size: 0.95rem;
  }
  .article-body :global(strong) { color: var(--ink); }
  .article-body :global(blockquote) {
    border-left: 2px solid var(--gold);
    padding: 0.8rem 1.5rem;
    background: var(--parchment-warm);
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--ink-muted);
  }
  .article-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }
  .article-body :global(th),
  .article-body :global(td) {
    padding: 0.7rem 1rem;
    border-bottom: 1px solid var(--cream);
    text-align: left;
  }
  .article-body :global(th) {
    font-weight: 600;
    color: var(--ink);
    font-size: 0.85rem;
    letter-spacing: 0.03em;
  }
  .article-body :global(td) {
    color: var(--ink-muted);
  }
  .article-body :global(hr) {
    border: none;
    height: 1px;
    background: var(--cream);
    margin: 2rem 0;
  }

  .article-cta {
    text-align: center;
    margin-top: 3rem;
    padding: 2.5rem;
    border: 1px solid var(--cream);
    background: var(--white);
  }
  .cta-divider {
    margin-bottom: 1rem;
    font-size: 1.2rem;
    opacity: 0.5;
  }
  .article-cta p {
    font-size: 1rem;
    color: var(--ink-muted);
    margin-bottom: 1.2rem;
    font-family: var(--font-serif);
  }
  .cta-button {
    display: inline-block;
    background: var(--tea-green);
    color: var(--white) !important;
    padding: 0.8rem 2.5rem;
    font-family: var(--font-serif);
    font-weight: 600;
    letter-spacing: 0.08em;
    transition: all var(--transition);
  }
  .cta-button:hover {
    background: var(--tea-green-deep);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .article-body { padding: 2rem 1.5rem; }
  }
</style>
