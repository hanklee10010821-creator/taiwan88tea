---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
).slice(0, 3);
---

<Base title="88茶葉｜台灣高山茶宅配到府" description="88茶葉提供台灣高山茶宅配貨到付款，梨山、阿里山、杉林溪、鹿谷茶葉直送到家。138則五星好評，不滿意保證退費！">

  <!-- Hero -->
  <section class="hero">
    <img src="/images/hero-tea.jpg" alt="台灣高山茶" class="hero-bg" loading="eager" />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="hero-badge">EST. 88茶葉</div>
      <h1>來自台灣高山的<br/>好茶，宅配到家</h1>
      <p class="hero-sub">梨山・阿里山・杉林溪・鹿谷<br/>海拔 1,000～2,600 公尺，產地直送</p>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-num">7,500+</span>
          <span class="stat-label">茶友信賴</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num">138</span>
          <span class="stat-label">五星好評</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num">100%</span>
          <span class="stat-label">退費保證</span>
        </div>
      </div>
      <a href="https://line.me/ti/p/%40wgc0409f" target="_blank" rel="noopener" class="hero-cta">
        加 LINE 選茶 →
      </a>
    </div>
  </section>

  <!-- 特色橫條 -->
  <section class="features-bar">
    <div class="features-inner">
      <div class="feature-item">
        <span class="feature-icon">🏔️</span>
        <span>產地直送</span>
      </div>
      <div class="feature-item">
        <span class="feature-icon">📦</span>
        <span>貨到付款</span>
      </div>
      <div class="feature-item">
        <span class="feature-icon">🔄</span>
        <span>不滿意退費</span>
      </div>
      <div class="feature-item">
        <span class="feature-icon">💬</span>
        <span>售後諮詢</span>
      </div>
    </div>
  </section>

  <!-- 理念 -->
  <section class="philosophy">
    <div class="section-inner">
      <div class="philosophy-layout">
        <div class="philosophy-img-wrap">
          <img src="/images/tea-pour.jpg" alt="茶壺泡茶" loading="lazy" />
        </div>
        <div class="philosophy-text">
          <span class="section-tag">我們的堅持</span>
          <h2>從茶山到你的杯中</h2>
          <p>好茶不應該只在茶行才喝得到。透過產地直送、貨到付款，讓你在家就能輕鬆品嚐台灣頂級高山茶。</p>
          <p><strong>不滿意？全額退費。</strong>這是我們對品質的信心。</p>
          <a href="/about" class="text-link">了解更多 →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 茶區 -->
  <section class="regions">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-tag">嚴選茶區</span>
        <h2>台灣四大高山茶產區</h2>
      </div>
      <div class="region-grid">
        <div class="region-card">
          <div class="region-top">
            <h3>梨山</h3>
            <span class="region-alt">2,000m+</span>
          </div>
          <p>台灣最高茶區。果香清甜，喉韻深長，高山茶的頂級代表。</p>
        </div>
        <div class="region-card">
          <div class="region-top">
            <h3>阿里山</h3>
            <span class="region-alt">1,200m+</span>
          </div>
          <p>雲霧繚繞的經典茶區。花香顯著、滋味甘醇，最受歡迎的台灣茶。</p>
        </div>
        <div class="region-card">
          <div class="region-top">
            <h3>杉林溪</h3>
            <span class="region-alt">1,600m+</span>
          </div>
          <p>杉木林環繞的秘境。獨特的杉木清香，入口清爽不膩。</p>
        </div>
        <div class="region-card">
          <div class="region-top">
            <h3>鹿谷</h3>
            <span class="region-alt">800m+</span>
          </div>
          <p>凍頂烏龍發源地。傳統炭焙工藝，濃郁焙火香，回甘持久。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 大圖 Banner -->
  <section class="mid-banner">
    <img src="/images/tea-leaves.jpg" alt="茶葉" class="mid-banner-bg" loading="lazy" />
    <div class="mid-banner-overlay"></div>
    <div class="mid-banner-content">
      <span class="section-tag section-tag-light">品質承諾</span>
      <h2>138 則五星好評<br/>7,500+ 茶友的選擇</h2>
      <a href="https://line.me/ti/p/%40wgc0409f" target="_blank" rel="noopener" class="banner-cta">立即體驗 →</a>
    </div>
  </section>

  <!-- 茶知識 -->
  {posts.length > 0 && (
    <section class="blog-section">
      <div class="section-inner">
        <div class="section-header">
          <span class="section-tag">茶知識</span>
          <h2>讓每一杯都更好喝</h2>
        </div>
        <div class="post-list">
          {posts.map((post, i) => (
            <a href={`/blog/${post.id}`} class="post-item">
              <div class="post-left">
                <span class="post-num">{String(i + 1).padStart(2, '0')}</span>
              </div>
              <div class="post-right">
                <h3>{post.data.title}</h3>
                <span class="post-arrow">→</span>
              </div>
            </a>
          ))}
        </div>
        <div class="section-more">
          <a href="/blog" class="more-link">查看全部文章 →</a>
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-inner">
      <span class="section-tag section-tag-light">開始品茶</span>
      <h2>想喝好茶？<br/>加我們 LINE 就對了</h2>
      <p>專人為你推薦最適合的茶葉</p>
      <a href="https://line.me/ti/p/%40wgc0409f" target="_blank" rel="noopener" class="cta-btn">
        加 LINE 好友 →
      </a>
    </div>
  </section>

</Base>

<style is:global>
  /* ======= HERO ======= */
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #1a2618;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.35;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(26,38,24,0.3) 0%, rgba(26,38,24,0.1) 40%, rgba(26,38,24,0.6) 100%);
  }
  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 6rem 1.5rem 3rem;
    max-width: 700px;
    color: var(--white);
  }
  .hero-badge {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.35em;
    color: var(--gold);
    border: 1px solid rgba(200,169,110,0.3);
    padding: 0.35rem 1.2rem;
    margin-bottom: 2rem;
  }
  .hero h1 {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 6vw, 3.5rem);
    font-weight: 700;
    letter-spacing: 0.05em;
    line-height: 1.4;
    margin-bottom: 1.2rem;
  }
  .hero-sub {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.8;
    letter-spacing: 0.05em;
    margin-bottom: 2rem;
  }
  .hero-stats {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }
  .stat { text-align: center; }
  .stat-num {
    display: block;
    font-family: var(--font-serif);
    font-size: clamp(1.3rem, 4vw, 1.8rem);
    font-weight: 700;
    color: var(--gold);
  }
  .stat-label {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.45);
    letter-spacing: 0.08em;
  }
  .stat-divider {
    width: 1px;
    height: 32px;
    background: rgba(200,169,110,0.2);
  }
  .hero-cta {
    display: inline-block;
    background: var(--gold);
    color: var(--ink) !important;
    padding: 0.9rem 2.5rem;
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    transition: all var(--transition);
  }
  .hero-cta:hover {
    background: var(--gold-light);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(200,169,110,0.3);
  }

  /* ======= FEATURES BAR ======= */
  .features-bar {
    background: var(--ink);
    padding: 1.2rem 1.5rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .features-inner {
    max-width: var(--content-width);
    margin: 0 auto;
    display: flex;
    justify-content: center;
    gap: 2.5rem;
  }
  .feature-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255,255,255,0.7);
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }
  .feature-icon { font-size: 1rem; }

  /* ======= SECTIONS COMMON ======= */
  .section-inner {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: var(--section-pad) 1.5rem;
  }
  .section-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .section-tag {
    display: inline-block;
    font-size: 0.68rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold-dark);
    margin-bottom: 0.8rem;
    font-weight: 500;
  }
  .section-tag-light { color: var(--gold-light); }
  .section-header h2 {
    font-size: clamp(1.4rem, 4vw, 2rem);
    color: var(--ink);
    margin-bottom: 0.5rem;
  }

  /* ======= PHILOSOPHY ======= */
  .philosophy {
    background: var(--white);
  }
  .philosophy-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .philosophy-img-wrap {
    overflow: hidden;
  }
  .philosophy-img-wrap img {
    width: 100%;
    height: 450px;
    object-fit: cover;
  }
  .philosophy-text .section-tag { margin-bottom: 0.8rem; }
  .philosophy-text h2 {
    font-size: clamp(1.3rem, 3vw, 1.8rem);
    margin-bottom: 1.2rem;
    color: var(--ink);
  }
  .philosophy-text p {
    color: var(--ink-muted);
    margin-bottom: 0.8rem;
    font-size: 0.92rem;
    line-height: 1.85;
  }
  .philosophy-text strong { color: var(--ink); }
  .text-link {
    display: inline-block;
    margin-top: 0.5rem;
    font-size: 0.85rem;
    color: var(--gold-dark);
    font-weight: 500;
    letter-spacing: 0.04em;
  }
  .text-link:hover { color: var(--ink); }

  /* ======= REGIONS ======= */
  .regions {
    background: var(--parchment-warm);
  }
  .region-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  .region-card {
    background: var(--white);
    padding: 2rem 1.5rem;
    border: 1px solid var(--cream);
    transition: all var(--transition);
  }
  .region-card:hover {
    border-color: var(--gold-light);
    box-shadow: var(--shadow-md);
  }
  .region-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.8rem;
  }
  .region-card h3 {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    color: var(--ink);
    letter-spacing: 0.06em;
  }
  .region-alt {
    font-size: 0.65rem;
    color: var(--gold-dark);
    letter-spacing: 0.15em;
    font-weight: 500;
  }
  .region-card p {
    font-size: 0.85rem;
    color: var(--ink-muted);
    line-height: 1.7;
  }

  /* ======= MID BANNER ======= */
  .mid-banner {
    position: relative;
    padding: 5rem 1.5rem;
    overflow: hidden;
    background: #1a2618;
  }
  .mid-banner-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.25;
  }
  .mid-banner-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(26,38,24,0.7), rgba(45,66,40,0.5));
  }
  .mid-banner-content {
    position: relative;
    z-index: 1;
    text-align: center;
    color: var(--white);
    max-width: 600px;
    margin: 0 auto;
  }
  .mid-banner-content h2 {
    font-size: clamp(1.4rem, 4.5vw, 2rem);
    color: var(--white);
    margin-bottom: 1.5rem;
    line-height: 1.5;
  }
  .banner-cta {
    display: inline-block;
    border: 1px solid var(--gold);
    color: var(--gold) !important;
    padding: 0.7rem 2rem;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    transition: all var(--transition);
  }
  .banner-cta:hover {
    background: var(--gold);
    color: var(--ink) !important;
  }

  /* ======= BLOG ======= */
  .blog-section {
    background: var(--white);
  }
  .post-list {
    display: flex;
    flex-direction: column;
  }
  .post-item {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--cream);
    color: var(--ink);
    transition: all var(--transition);
  }
  .post-item:first-child { border-top: 1px solid var(--cream); }
  .post-item:hover { color: var(--ink); }
  .post-item:hover .post-num { color: var(--gold); }
  .post-item:hover .post-arrow { color: var(--gold); transform: translateX(4px); }
  .post-left { flex-shrink: 0; }
  .post-num {
    font-family: var(--font-serif);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--cream);
    transition: color var(--transition);
  }
  .post-right {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .post-item h3 {
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--ink);
    font-weight: 500;
  }
  .post-arrow {
    flex-shrink: 0;
    color: var(--cream);
    font-size: 1.1rem;
    transition: all var(--transition);
  }
  .section-more {
    text-align: center;
    margin-top: 2rem;
  }
  .more-link {
    font-size: 0.85rem;
    color: var(--gold-dark);
    font-weight: 500;
    letter-spacing: 0.05em;
  }

  /* ======= CTA ======= */
  .cta-section {
    background: linear-gradient(165deg, #1a2618 0%, #2d4228 40%, #1a2218 100%);
    color: var(--white);
    text-align: center;
  }
  .cta-inner {
    max-width: 600px;
    margin: 0 auto;
    padding: var(--section-pad) 1.5rem;
  }
  .cta-inner h2 {
    font-size: clamp(1.4rem, 4vw, 2rem);
    color: var(--white);
    margin-bottom: 0.8rem;
  }
  .cta-inner p {
    color: rgba(255,255,255,0.55);
    margin-bottom: 2rem;
    letter-spacing: 0.04em;
  }
  .cta-btn {
    display: inline-block;
    background: var(--gold);
    color: var(--ink) !important;
    padding: 0.9rem 2.5rem;
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    transition: all var(--transition);
  }
  .cta-btn:hover {
    background: var(--gold-light);
    transform: translateY(-2px);
  }

  /* ======= MOBILE ======= */
  @media (max-width: 768px) {
    .hero {
      min-height: 100vh;
      min-height: 100svh;
    }
    .hero-content {
      padding: 5rem 1.5rem 2.5rem;
    }
    .hero-stats { gap: 1rem; }

    .features-inner {
      justify-content: flex-start;
      gap: 1.5rem;
      padding: 0 0.5rem;
    }

    .philosophy-layout {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .philosophy-img-wrap img {
      height: 280px;
    }

    .region-grid {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .region-card {
      border-left: none;
      border-right: none;
      border-radius: 0;
    }
    .region-card + .region-card {
      border-top: none;
    }

    .mid-banner { padding: 4rem 1.5rem; }

    .post-item { gap: 1rem; }
    .post-num { font-size: 1.4rem; }
    .post-item h3 { font-size: 0.88rem; }
  }

  /* ======= DESKTOP ======= */
  @media (min-width: 1025px) {
    .region-grid { grid-template-columns: repeat(4, 1fr); }
  }
</style>
