</Base>

<style is:global>
  /* ======= HERO ======= */
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #1a2618;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.35;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(26,38,24,0.3) 0%, rgba(26,38,24,0.1) 40%, rgba(26,38,24,0.6) 100%);
  }
  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 6rem 1.5rem 3rem;
    max-width: 700px;
    color: var(--white);
  }
  .hero-badge {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.35em;
    color: var(--gold);
    border: 1px solid rgba(200,169,110,0.3);
    padding: 0.35rem 1.2rem;
    margin-bottom: 2rem;
  }
  .hero h1 {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 6vw, 3.5rem);
    font-weight: 700;
    letter-spacing: 0.05em;
    line-height: 1.4;
    margin-bottom: 1.2rem;
  }
  .hero-sub {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.8;
    letter-spacing: 0.05em;
    margin-bottom: 2rem;
  }
  .hero-stats {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }
  .stat { text-align: center; }
  .stat-num {
    display: block;
    font-family: var(--font-serif);
    font-size: clamp(1.3rem, 4vw, 1.8rem);
    font-weight: 700;
    color: var(--gold);
  }
  .stat-label {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.45);
    letter-spacing: 0.08em;
  }
  .stat-divider {
    width: 1px;
    height: 32px;
    background: rgba(200,169,110,0.2);
  }
  .hero-cta {
    display: inline-block;
    background: var(--gold);
    color: var(--ink) !important;
    padding: 0.9rem 2.5rem;
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    transition: all var(--transition);
  }
  .hero-cta:hover {
    background: var(--gold-light);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(200,169,110,0.3);
  }

  /* ======= FEATURES BAR ======= */
  .features-bar {
    background: var(--ink);
    padding: 1.2rem 1.5rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .features-inner {
    max-width: var(--content-width);
    margin: 0 auto;
    display: flex;
    justify-content: center;
    gap: 2.5rem;
  }
  .feature-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255,255,255,0.7);
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }
  .feature-icon { font-size: 1rem; }

  /* ======= SECTIONS COMMON ======= */
  .section-inner {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: var(--section-pad) 1.5rem;
  }
  .section-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .section-tag {
    display: inline-block;
    font-size: 0.68rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold-dark);
    margin-bottom: 0.8rem;
    font-weight: 500;
  }
  .section-tag-light { color: var(--gold-light); }
  .section-header h2 {
    font-size: clamp(1.4rem, 4vw, 2rem);
    color: var(--ink);
    margin-bottom: 0.5rem;
  }

  /* ======= PHILOSOPHY ======= */
  .philosophy {
    background: var(--white);
  }
  .philosophy-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .philosophy-img-wrap {
    overflow: hidden;
  }
  .philosophy-img-wrap img {
    width: 100%;
    height: 450px;
    object-fit: cover;
  }
  .philosophy-text .section-tag { margin-bottom: 0.8rem; }
  .philosophy-text h2 {
    font-size: clamp(1.3rem, 3vw, 1.8rem);
    margin-bottom: 1.2rem;
    color: var(--ink);
  }
  .philosophy-text p {
    color: var(--ink-muted);
    margin-bottom: 0.8rem;
    font-size: 0.92rem;
    line-height: 1.85;
  }
  .philosophy-text strong { color: var(--ink); }
  .text-link {
    display: inline-block;
    margin-top: 0.5rem;
    font-size: 0.85rem;
    color: var(--gold-dark);
    font-weight: 500;
    letter-spacing: 0.04em;
  }
  .text-link:hover { color: var(--ink); }

  /* ======= REGIONS ======= */
  .regions {
    background: var(--parchment-warm);
  }
  .region-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  .region-card {
    background: var(--white);
    padding: 2rem 1.5rem;
    border: 1px solid var(--cream);
    transition: all var(--transition);
  }
  .region-card:hover {
    border-color: var(--gold-light);
    box-shadow: var(--shadow-md);
  }
  .region-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.8rem;
  }
  .region-card h3 {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    color: var(--ink);
    letter-spacing: 0.06em;
  }
  .region-alt {
    font-size: 0.65rem;
    color: var(--gold-dark);
    letter-spacing: 0.15em;
    font-weight: 500;
  }
  .region-card p {
    font-size: 0.85rem;
    color: var(--ink-muted);
    line-height: 1.7;
  }

  /* ======= MID BANNER ======= */
  .mid-banner {
    position: relative;
    padding: 5rem 1.5rem;
    overflow: hidden;
    background: #1a2618;
  }
  .mid-banner-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
