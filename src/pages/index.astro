---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
).slice(0, 3);
---

<Base title="88茶葉｜台灣高山茶宅配到府" description="88茶葉提供台灣高山茶宅配貨到付款，梨山、阿里山、杉林溪、鹿谷茶葉直送到家。138則五星好評，不滿意保證退費！">

  <!-- Promo Banner -->
  <div style="background: var(--gold-dark); color: white; text-align: center; padding: 0.8rem 1rem; font-size: 0.95rem; font-weight: 500; letter-spacing: 0.05em; position: relative; z-index: 10;">
    🌟 <b>【2026早春採收】</b>頂級高山生茶，新鮮下山！阿里山 vs 杉林溪，老客戶回饋 <b>買 2 斤送 1 斤</b> (限量) 
    <a href="https://line.me/ti/p/%40wgc0409f" style="color: white; text-decoration: underline; margin-left: 10px; font-weight: bold;">點此加 LINE 領取優惠 →</a>
  </div>

  <!-- Hero -->
  <section class="hero">
    <img src="/images/hero-tea.jpg" alt="台灣高山茶" class="hero-bg" loading="eager" />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="hero-badge">EST. 88茶葉</div>
      <h1>來自台灣高山的<br/>好茶，宅配到家</h1>
      <p class="hero-sub">梨山・阿里山・杉林溪・鹿谷<br/>海拔 1,000～2,600 公尺，產地直送</p>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-num">7,500+</span>
          <span class="stat-label">茶友信賴</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num">138</span>
          <span class="stat-label">五星好評</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num">100%</span>
          <span class="stat-label">退費保證</span>
        </div>
      </div>
      <a href="https://line.me/ti/p/%40wgc0409f" target="_blank" rel="noopener" class="hero-cta">
        加 LINE 選茶 →
      </a>
    </div>
  </section>

  <!-- 特色橫條 -->
  <section class="features-bar">
    <div class="features-inner">
      <div class="feature-item">
        <span class="feature-icon">🏔️</span>
        <span>產地直送</span>
      </div>
      <div class="feature-item">
        <span class="feature-icon">📦</span>
        <span>貨到付款</span>
      </div>
      <div class="feature-item">
        <span class="feature-icon">🔄</span>
        <span>不滿意退費</span>
      </div>
      <div class="feature-item">
        <span class="feature-icon">💬</span>
        <span>售後諮詢</span>
      </div>
    </div>
  </section>

  <!-- 理念 -->
  <section class="philosophy">
    <div class="section-inner">
      <div class="philosophy-layout">
        <div class="philosophy-img-wrap">
          <img src="/images/tea-pour.jpg" alt="茶壺泡茶" loading="lazy" />
        </div>
        <div class="philosophy-text">
          <span class="section-tag">我們的堅持</span>
          <h2>從茶山到你的杯中</h2>
          <p>好茶不應該只在茶行才喝得到。透過產地直送、貨到付款，讓你在家就能輕鬆品嚐台灣頂級高山茶。</p>
          <p><strong>不滿意？全額退費。</strong>這是我們對品質的信心。</p>
          <a href="/about" class="text-link">了解更多 →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 茶區 -->
  <section class="regions">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-tag">嚴選茶區</span>
        <h2>台灣四大高山茶產區</h2>
      </div>
      <div class="region-grid">
        <div class="region-card">
          <div class="region-top">
            <h3>梨山</h3>
            <span class="region-alt">2,000m+</span>
          </div>
          <p>台灣最高茶區。果香清甜，喉韻深長，高山茶的頂級代表。</p>
        </div>
        <div class="region-card">
          <div class="region-top">
            <h3>阿里山</h3>
            <span class="region-alt">1,200m+</span>
          </div>
          <p>雲霧繚繞的經典茶區。花香顯著、滋味甘醇，最受歡迎的台灣茶。</p>
        </div>
        <div class="region-card">
          <div class="region-top">
            <h3>杉林溪</h3>
            <span class="region-alt">1,600m+</span>
          </div>
          <p>杉木林環繞的秘境。獨特的杉木清香，入口清爽不膩。</p>
        </div>
        <div class="region-card">
          <div class="region-top">
            <h3>鹿谷</h3>
            <span class="region-alt">800m+</span>
          </div>
          <p>凍頂烏龍發源地。傳統炭焙工藝，濃郁焙火香，回甘持久。</p>
        </div>
      </div>
    </div>
  </section>

  
  <!-- 安心保證 -->
  <section class="trust-section">
    <div class="section-inner trust-layout">
      <div class="trust-img">
        <div class="trust-badge">SGS</div>
        <img src="/images/tea-pour.jpg" alt="茶葉檢驗" loading="lazy" style="filter: brightness(0.8) sepia(0.2);" />
      </div>
      <div class="trust-text">
        <span class="section-tag">安心保證</span>
        <h2>100% 台灣茶，無農藥殘留</h2>
        <p>每一批 88茶葉 上架前，皆通過 SGS 國家級農藥殘留檢驗，426 項農藥皆未檢出 (ND)。</p>
        <ul class="trust-list">
          <li>✔️ 拒絕混充：保證 100% 台灣高山茶，絕不混入低價進口茶。</li>
          <li>✔️ 嚴格把關：不使用化學香精，所有花香、冷礦味皆為天然茶氣。</li>
          <li>✔️ 退費承諾：只要喝不習慣，不用任何理由，全額退換貨。</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- 常見問題 FAQ -->
  <section class="faq-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-tag">顧客問答</span>
        <h2>常見問題 FAQ</h2>
      </div>
      <div class="faq-grid">
        <div class="faq-card">
          <h4>Q: 我怕茶太苦澀，推薦哪一款？</h4>
          <p>A: 推薦您選擇【阿里山春茶】。它的果膠質最豐富，口感非常甘甜柔順，是入門與怕苦澀茶友的最佳選擇。</p>
        </div>
        <div class="faq-card">
          <h4>Q: 下單後大約多久可以收到？</h4>
          <p>A: 我們採用新竹物流宅配，通常今天下單，明天出貨，後天就能送達您手中（偏遠地區約需多1-2天）。</p>
        </div>
        <div class="faq-card">
          <h4>Q: 買 2 送 1 可以混搭嗎？</h4>
          <p>A: 可以的！阿里山與杉林溪可以任意混搭（例如 2斤阿里山 + 1斤杉林溪）。</p>
        </div>
        <div class="faq-card">
          <h4>Q: 如果真的喝不習慣怎麼辦？</h4>
          <p>A: 沒問題！只要您保持剩下的茶葉包裝完整，聯繫我們的 LINE 客服，我們將為您安排退費或換茶，買茶零風險。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 大圖 Banner -->
  <section class="mid-banner">
    <img src="/images/tea-leaves.jpg" alt="茶葉" class="mid-banner-bg" loading="lazy" />
    <div class="mid-banner-overlay"></div>
    <div class="mid-banner-content">
      <span class="section-tag section-tag-light">品質承諾</span>
      <h2>138 則五星好評<br/>7,500+ 茶友的選擇</h2>
      <a href="https://line.me/ti/p/%40wgc0409f" target="_blank" rel="noopener" class="banner-cta">立即體驗 →</a>
    </div>
  </section>

  
  <!-- 品牌歷史回顧 (自動同步FB) -->
  <section class="fb-history-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-tag">品牌足跡</span>
        <h2>茶友們共同見證的好味道</h2>
      </div>
      <div class="history-grid">

        <div class="history-card">
          <div class="history-img"><img src="https://scontent.ftpe7-2.fna.fbcdn.net/v/t39.30808-6/685148293_1407256668087467_2708897760502781629_n.jpg?stp=dst-jpg_s720x720_tt6&_nc_cat=109&ccb=1-7&_nc_sid=13d280&_nc_ohc=jlYTgEG7KTYQ7kNvwHqqKb8&_nc_oc=Adr5QQcq85SBRvoCbbEMjLwUwicce5-bRqWH4xSwaIHENSJ2X24VTk4vOiMyW_dEXKI&_nc_zt=23&_nc_ht=scontent.ftpe7-2.fna&edm=AKIiGfEEAAAA&_nc_gid=LgatK9sjKl3v_kKUiqhKuw&_nc_tpa=Q5bMBQF9ArfQP2G16uzeXY3LB7qoJEX99c-VjribBzpUWYX2c89NafHzkaXrvJJLzsbA46xQUqTmYL5h&oh=00_Af6tmx1R9mW9KoRHo6P_FuhUvB9PEljbU0yTZVwqaQa6wQ&oe=69FB8744" alt="FB Post" loading="lazy" /></div>
          <div class="history-content">
            <p>"【今年春茶，你選阿里山還是杉林溪？🤔】  很多茶友私訊問我們：「老闆，阿里山跟杉林溪到底差在哪？我怕苦澀該喝哪一種？」 ..."</p>
            <span class="history-date">Facebook 粉絲團貼文</span>
          </div>
        </div>
        <div class="history-card">
          <div class="history-img"><img src="https://scontent.ftpe7-1.fna.fbcdn.net/v/t39.30808-6/673502681_1395568749256259_2104911829219690645_n.jpg?stp=dst-jpg_p720x720_tt6&_nc_cat=110&ccb=1-7&_nc_sid=13d280&_nc_ohc=fpmF6-NR42YQ7kNvwHNaLvA&_nc_oc=AdqUxpyNayoTRGgs_Tz2hYUMZOjb0u8Q177wKVblLb0636uj4Dg86zLpnpe7ZMVcijQ&_nc_zt=23&_nc_ht=scontent.ftpe7-1.fna&edm=AKIiGfEEAAAA&_nc_gid=LgatK9sjKl3v_kKUiqhKuw&_nc_tpa=Q5bMBQGauKLLgwufjEzhmZdMxVrt3BjD7hgmiyLKYCtCFMjliB3GZOxUxdwNBodJziYGPey3qG8XVlfs&oh=00_Af5FY3uC9JshZMJEG_ttTp9bXJMdL6vZv5Ib32Y7OCFYjg&oe=69FB8116" alt="FB Post" loading="lazy" /></div>
          <div class="history-content">
            <p>"☁️ 海拔 2,000 公尺以上，雲霧繚繞 梨山高冷茶，台灣頂級高山茶的代表  果香清甜、喉韻深長 每一口，都是山林給你..."</p>
            <span class="history-date">Facebook 粉絲團貼文</span>
          </div>
        </div>
        <div class="history-card">
          <div class="history-img"><img src="https://scontent.ftpe7-3.fna.fbcdn.net/v/t39.30808-6/668857487_1389052589907875_9016622297629417418_n.jpg?stp=dst-jpg_p720x720_tt6&_nc_cat=102&ccb=1-7&_nc_sid=13d280&_nc_ohc=fiFJY-RBt18Q7kNvwF4Lhb1&_nc_oc=AdqzD2haxZOwhAwLPD_sgxi9wITv5OjHnzTN31MzhMu65LSjxyGQjAnEFU2fTOZDGpY&_nc_zt=23&_nc_ht=scontent.ftpe7-3.fna&edm=AKIiGfEEAAAA&_nc_gid=LgatK9sjKl3v_kKUiqhKuw&_nc_tpa=Q5bMBQEyFVlpnYmTfQlgH5X5IJ2Zk4TCJ4tRP_LQlk8iXeCkn4edPyQ15GLQvrLeOsb-_bGjljIdHcxE&oh=00_Af7Y53_xr5Rhv5l9bshox250jLQvV7iFaOeckpR6zH9nUQ&oe=69FB8948" alt="FB Post" loading="lazy" /></div>
          <div class="history-content">
            <p>"茶香裡的慢時光：尋找內心的寧靜片刻  午後的陽光灑落，溫潤的茶香在空氣中輕輕蔓延。此刻，時間彷彿慢了下來，只剩下茶湯在杯..."</p>
            <span class="history-date">Facebook 粉絲團貼文</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 茶知識 -->
  {posts.length > 0 && (
    <section class="blog-section">
      <div class="section-inner">
        <div class="section-header">
          <span class="section-tag">茶知識</span>
          <h2>讓每一杯都更好喝</h2>
        </div>
        <div class="post-list">
          {posts.map((post, i) => (
            <a href={`/blog/${post.id}`} class="post-item">
              <div class="post-left">
                <span class="post-num">{String(i + 1).padStart(2, '0')}</span>
              </div>
              <div class="post-right">
                <h3>{post.data.title}</h3>
                <span class="post-arrow">→</span>
              </div>
            </a>
          ))}
